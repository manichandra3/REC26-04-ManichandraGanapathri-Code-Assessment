# Copy this file to `.env` and fill in your key.
#   cp .env.example .env

# Required: Google Gemini API key (free tier works). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional overrides (sensible defaults are used if unset):
# GEMINI_MODEL=gemini-2.5-flash-lite
# TOP_K=5
